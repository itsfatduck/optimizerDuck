<UserControl
    x:Class="optimizerDuck.UI.Dialogs.ScheduledTaskDeleteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:optimizerDuck.UI.Controls"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:optimizerDuck.UI.ViewModels.Dialogs"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type=dialogs:ScheduledTaskDeleteDialogViewModel}"
    d:DesignHeight="400"
    d:DesignWidth="600"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>
    <Grid MinWidth="480">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Warning banner  -->
        <ui:InfoBar
            Grid.Row="0"
            Margin="0,0,0,12"
            IsClosable="False"
            IsOpen="True"
            Message="{ext:Loc ScheduledTasks.Dialog.DeleteWarning}"
            Severity="Warning" />

        <!--  Task card  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="16"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerRadiusMedium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image
                    Grid.Column="0"
                    Width="40"
                    Height="40"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Source="{Binding Task.LogoImage}"
                    Stretch="UniformToFill" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <DockPanel LastChildFill="False">
                        <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Task.Name}" />
                        <Border
                            Margin="8,0,0,0"
                            Padding="6,1"
                            VerticalAlignment="Center"
                            CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Task.IsReady}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Task.IsRunning}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Task.IsDisabledState}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon
                                    x:Name="StateIcon"
                                    Margin="0,0,4,0"
                                    FontSize="10">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Setter Property="Symbol" Value="Circle24" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Task.IsReady}" Value="True">
                                                    <Setter Property="Symbol" Value="CheckmarkCircle24" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorInverseBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Task.IsRunning}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorInverseBrush}" />
                                                    <Setter Property="Symbol" Value="Play24" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Task.IsDisabledState}" Value="True">
                                                    <Setter Property="Symbol" Value="Dismiss24" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorInverseBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                                <ui:TextBlock
                                    FontTypography="Caption"
                                    Foreground="{Binding ElementName=StateIcon, Path=Foreground}"
                                    Text="{Binding Task.State}" />
                            </StackPanel>
                        </Border>
                    </DockPanel>

                    <ui:TextBlock
                        Margin="0,4,0,0"
                        FontTypography="Caption"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Task.Description}"
                        TextWrapping="Wrap" />

                    <ui:TextBlock
                        Margin="0,2,0,0"
                        FontTypography="Caption"
                        Foreground="{DynamicResource TextFillColorDisabledBrush}"
                        Text="{Binding Task.FullPath}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Details grid  -->
        <Border
            Grid.Row="2"
            Padding="16"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerRadiusMedium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <!--  Author  -->
                <ui:SymbolIcon
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Symbol="Person24" />
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,16,0">
                    <ui:TextBlock
                        Appearance="Secondary"
                        FontTypography="Caption"
                        Text="{ext:Loc ScheduledTasks.Details.Author}" />
                    <ui:TextBlock
                        Margin="0,2,0,0"
                        FontTypography="Body"
                        Text="{Binding Task.Author}"
                        Visibility="{Binding Task.IsAuthorEmpty, Converter={StaticResource InverseBoolToVis}}" />
                    <controls:EmptyBadge Margin="0,2,0,0" Visibility="{Binding Task.IsAuthorEmpty, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <!--  Triggers  -->
                <ui:SymbolIcon
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="0,0,8,0"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Symbol="Timer24" />
                <StackPanel Grid.Row="0" Grid.Column="3">
                    <ui:TextBlock
                        Appearance="Secondary"
                        FontTypography="Caption"
                        Text="{ext:Loc ScheduledTasks.Details.Triggers}" />
                    <ui:TextBlock
                        Margin="0,2,0,0"
                        FontTypography="Body"
                        Text="{Binding Task.TriggerSummary}"
                        TextWrapping="Wrap"
                        Visibility="{Binding Task.IsTriggersEmpty, Converter={StaticResource InverseBoolToVis}}" />
                    <controls:EmptyBadge Margin="0,2,0,0" Visibility="{Binding Task.IsTriggersEmpty, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <!--  Action  -->
                <ui:SymbolIcon
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,8,8,0"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Symbol="Play24" />
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="4"
                    Margin="0,8,16,0">
                    <ui:TextBlock
                        Appearance="Secondary"
                        FontTypography="Caption"
                        Text="{ext:Loc ScheduledTasks.Details.Action}" />
                    <ui:TextBlock
                        Margin="0,2,0,0"
                        FontFamily="Consolas"
                        FontTypography="Body"
                        Text="{Binding Task.ActionSummary}"
                        TextWrapping="Wrap"
                        Visibility="{Binding Task.IsActionEmpty, Converter={StaticResource InverseBoolToVis}}" />
                    <controls:EmptyBadge Margin="0,2,0,0" Visibility="{Binding Task.IsActionEmpty, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
