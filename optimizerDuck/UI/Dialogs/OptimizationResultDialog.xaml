<UserControl
    x:Class="optimizerDuck.UI.Dialogs.OptimizationResultDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter
            x:Key="NullToVisibilityConverter"
            False="Visible"
            True="Collapsed" />
    </UserControl.Resources>
    <StackPanel MinWidth="560">
        <!--  Header with failed count summary  -->
        <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
            <ui:SymbolIcon
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Filled="True"
                Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                Symbol="ErrorCircle24" />

            <ui:TextBlock
                FontTypography="Subtitle"
                Text="{ext:Loc OptimizationResultDialog.Header,
                               {Binding FailedCount}}"
                TextTrimming="WordEllipsis"
                TextWrapping="Wrap" />
        </StackPanel>

        <ui:TextBlock
            Margin="0,2,0,12"
            Appearance="Secondary"
            FontTypography="Body"
            Text="{ext:Loc OptimizationResultDialog.Description}"
            TextWrapping="Wrap" />

        <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FailedSteps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardControl Margin="0,0,0,8">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <!--  Top row: index + service type badge + step name  -->
                                    <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                        <!--  Step index badge  -->
                                        <Border
                                            Margin="0,0,8,0"
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="4">
                                            <ui:TextBlock
                                                VerticalAlignment="Center"
                                                Appearance="Disabled"
                                                FontTypography="Caption"
                                                Text="{Binding Index, StringFormat=# {0}}" />
                                        </Border>

                                        <!--  Service type badge  -->
                                        <Border
                                            Margin="0,0,8,0"
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                                            CornerRadius="4">
                                            <ui:TextBlock
                                                VerticalAlignment="Center"
                                                FontTypography="Caption"
                                                Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                Text="{Binding Name}" />
                                        </Border>
                                    </StackPanel>

                                    <!--  Step description  -->
                                    <ui:TextBlock
                                        Margin="0,0,0,4"
                                        FontTypography="BodyStrong"
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap" />

                                    <!--  Error message  -->
                                    <Border
                                        Margin="0,4,0,0"
                                        Padding="8,6"
                                        HorizontalAlignment="Left"
                                        BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusMedium}"
                                        Visibility="{Binding Error, Converter={StaticResource NullToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Filled="True"
                                                Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                Symbol="Warning24" />
                                            <ui:TextBlock
                                                HorizontalAlignment="Stretch"
                                                FontTypography="Caption"
                                                Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                Text="{Binding Error}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
