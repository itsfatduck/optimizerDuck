<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="optimizerDuck.UI.Dialogs.OptimizationResultDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <UserControl.Resources>
        <converters:NullToVisibilityConverter
            False="Visible"
            True="Collapsed"
            x:Key="NullToVisibilityConverter"
        />
    </UserControl.Resources>
    <StackPanel>
        <!-- Header with failed count summary -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <ui:SymbolIcon
                Filled="True"
                Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                Margin="0,0,8,0"
                Symbol="ErrorCircle24"
                VerticalAlignment="Center"
            />

            <ui:TextBlock
                FontTypography="Subtitle"
                Text="{ext:Loc OptimizationResultDialog.Header,
                               {Binding FailedCount}}"
                TextTrimming="WordEllipsis"
                TextWrapping="Wrap"
            />
        </StackPanel>

        <ui:TextBlock
            Appearance="Secondary"
            FontTypography="Body"
            Margin="0,2,0,12"
            Text="{ext:Loc OptimizationResultDialog.Description}"
            TextWrapping="Wrap"
        />

        <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FailedSteps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardControl Margin="0,0,0,8">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <!-- Top row: index + service type badge + step name -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <!-- Step index badge -->
                                        <Border
                                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,8,0"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                        >
                                            <ui:TextBlock
                                                Appearance="Disabled"
                                                FontTypography="Caption"
                                                Text="{Binding Index, StringFormat=# {0}}"
                                                VerticalAlignment="Center"
                                            />
                                        </Border>

                                        <!-- Service type badge -->
                                        <Border
                                            Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,8,0"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                        >
                                            <ui:TextBlock
                                                FontTypography="Caption"
                                                Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                Text="{Binding Name}"
                                                VerticalAlignment="Center"
                                            />
                                        </Border>
                                    </StackPanel>

                                    <!-- Step description -->
                                    <ui:TextBlock
                                        FontTypography="BodyStrong"
                                        Margin="0,0,0,4"
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap"
                                    />

                                    <!-- Error message -->
                                    <Border
                                        BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        HorizontalAlignment="Left"
                                        Margin="0,4,0,0"
                                        Padding="8,6"
                                        Visibility="{Binding Error, Converter={StaticResource NullToVisibilityConverter}}"
                                    >
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                Filled="True"
                                                Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                Margin="0,0,6,0"
                                                Symbol="Warning24"
                                                VerticalAlignment="Center"
                                            />
                                            <ui:TextBlock
                                                FontTypography="Caption"
                                                Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                HorizontalAlignment="Stretch"
                                                Text="{Binding Error}"
                                                TextWrapping="Wrap"
                                            />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
