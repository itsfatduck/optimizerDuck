<UserControl
    x:Class="optimizerDuck.UI.Dialogs.LegalDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="420"
    d:DesignWidth="520"
    mc:Ignorable="d"
>
    <Grid Style="{StaticResource DuckDialogRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <ui:TextBlock
                FontTypography="BodyStrong"
                Text="{ext:Loc LegalDialog.Intro.ThankYou}"
                TextWrapping="Wrap"
            />
            <ui:TextBlock
                Margin="0,8,0,0"
                FontTypography="Body"
                Text="{ext:Loc LegalDialog.Intro.Safety}"
                TextWrapping="Wrap"
            />
            <ui:TextBlock
                Margin="0,4,0,0"
                FontTypography="Body"
                Text="{ext:Loc LegalDialog.Intro.Review}"
                TextWrapping="Wrap"
            />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,12,0,12" Style="{StaticResource DuckToolbarSurfaceStyle}">
        <StackPanel>
            <ui:HyperlinkButton
                Content="{ext:Loc Key=LegalDialog.Link.TermsOfService}"
                Icon="{ui:SymbolIcon DocumentText24}"
                NavigateUri="https://github.com/itsfatduck/optimizerDuck/blob/master/TERMS.md"
            />

            <ui:HyperlinkButton
                Margin="0,4,0,0"
                Content="{ext:Loc Key=LegalDialog.Link.PrivacyPolicy}"
                Icon="{ui:SymbolIcon ShieldLock24}"
                NavigateUri="https://github.com/itsfatduck/optimizerDuck/blob/master/PRIVACY.md"
            />

            <ui:HyperlinkButton
                Margin="0,4,0,0"
                Content="{ext:Loc Key=LegalDialog.Link.Disclaimer}"
                Icon="{ui:SymbolIcon Warning24}"
                NavigateUri="https://github.com/itsfatduck/optimizerDuck/blob/master/DISCLAIMER.md"
            />
        </StackPanel>
        </Border>

        <ui:InfoBar
            Title="{ext:Loc Key=LegalDialog.Warning.Title}"
            Grid.Row="2"
            IsClosable="False"
            IsOpen="True"
            Message="{ext:Loc Key=LegalDialog.Warning.Message}"
            Severity="Warning"
        />
    </Grid>
</UserControl>
