<UserControl
    x:Class="optimizerDuck.UI.Dialogs.ScheduledTaskDetailsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:optimizerDuck.UI.Controls"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:optimizerDuck.Domain.Optimizations.Models.ScheduledTask"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type=models:ScheduledTaskModel}"
    d:DesignHeight="700"
    d:DesignWidth="760"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>
    <StackPanel>
        <Border
                Margin="0,0,0,12"
                Padding="{StaticResource CardPadding}"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusMedium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image
                        Grid.Column="0"
                        Width="40"
                        Height="40"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Source="{Binding LogoImage}"
                        Stretch="UniformToFill" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <DockPanel LastChildFill="False">
                        <ui:TextBlock
                                FontTypography="BodyStrong"
                                Text="{Binding Name}"
                                TextWrapping="Wrap" />
                        <Border
                                Margin="8,0,0,0"
                                Padding="6,1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="4">
                            <ui:TextBlock
                                    VerticalAlignment="Center"
                                    Appearance="Tertiary"
                                    FontTypography="Caption"
                                    Text="{ext:Loc ScheduledTasks.Header.Title}" />
                        </Border>
                        <Border
                                x:Name="StateBorder"
                                Margin="8,0,0,0"
                                Padding="6,1"
                                VerticalAlignment="Center"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon
                                        x:Name="StateIcon"
                                        Margin="0,0,4,0"
                                        FontSize="10"
                                        Symbol="Circle24" />
                                <ui:TextBlock
                                        VerticalAlignment="Center"
                                        FontTypography="Caption"
                                        Foreground="{Binding ElementName=StateIcon, Path=Foreground}"
                                        Text="{Binding State}" />
                            </StackPanel>
                        </Border>
                    </DockPanel>

                    <ui:TextBlock
                            Margin="0,4,0,0"
                            Appearance="Secondary"
                            FontTypography="Caption"
                            Text="{Binding Description}"
                            TextWrapping="Wrap"
                            Visibility="{Binding IsDescriptionEmpty, Converter={StaticResource InverseBoolToVis}}" />
                    <controls:EmptyBadge
                            Margin="0,2,0,0"
                            Visibility="{Binding IsDescriptionEmpty, Converter={StaticResource BoolToVis}}" />
                    <ui:TextBlock
                            Margin="0,2,0,0"
                            Appearance="Disabled"
                            FontTypography="Caption"
                            Text="{Binding FullPath}"
                            TextTrimming="CharacterEllipsis" />

                    <ItemsControl ItemsSource="{Binding TriggerTypes}" Margin="0,6,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                        Margin="0,0,4,2"
                                        Padding="6,2"
                                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon
                                                Margin="0,0,4,0"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Symbol="Timer24" />
                                        <ui:TextBlock
                                                VerticalAlignment="Center"
                                                FontTypography="Caption"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <Border
                Margin="0,0,0,12"
                Padding="0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusMedium}">
            <StackPanel>
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                            Margin="0,0,10,0"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Symbol="Person24" />
                    <StackPanel Grid.Column="1">
                        <ui:TextBlock
                                Appearance="Secondary"
                                FontTypography="Caption"
                                Text="{ext:Loc ScheduledTasks.Details.Author}" />
                        <ui:TextBlock
                                Margin="0,2,0,0"
                                FontTypography="Body"
                                Text="{Binding Author}"
                                Visibility="{Binding IsAuthorEmpty, Converter={StaticResource InverseBoolToVis}}" />
                        <controls:EmptyBadge
                                Margin="0,2,0,0"
                                Visibility="{Binding IsAuthorEmpty, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Grid>
                <Separator Margin="14,0" />

                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                            Margin="0,0,10,0"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Symbol="Timer24" />
                    <StackPanel Grid.Column="1">
                        <ui:TextBlock
                                Appearance="Secondary"
                                FontTypography="Caption"
                                Text="{ext:Loc ScheduledTasks.Details.Triggers}" />
                        <ui:TextBlock
                                Margin="0,2,0,0"
                                FontTypography="Body"
                                Text="{Binding TriggerSummary}"
                                TextWrapping="Wrap"
                                Visibility="{Binding IsTriggersEmpty, Converter={StaticResource InverseBoolToVis}}" />
                        <controls:EmptyBadge
                                Margin="0,2,0,0"
                                Visibility="{Binding IsTriggersEmpty, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Grid>
                <Separator Margin="14,0" />

                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                            Margin="0,0,10,0"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Symbol="Play24" />
                    <StackPanel Grid.Column="1">
                        <ui:TextBlock
                                Appearance="Secondary"
                                FontTypography="Caption"
                                Text="{ext:Loc ScheduledTasks.Details.Action}" />
                        <ui:TextBlock
                                Margin="0,2,0,0"
                                FontFamily="Consolas"
                                FontTypography="Body"
                                Text="{Binding ActionSummary}"
                                TextWrapping="Wrap"
                                Visibility="{Binding IsActionEmpty, Converter={StaticResource InverseBoolToVis}}" />
                        <controls:EmptyBadge
                                Margin="0,2,0,0"
                                Visibility="{Binding IsActionEmpty, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border
                Padding="0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusMedium}">
            <StackPanel>
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                            Margin="0,0,10,0"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Symbol="History24" />
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <ui:TextBlock
                                Appearance="Secondary"
                                FontTypography="Caption"
                                Text="{ext:Loc ScheduledTasks.Details.LastRun}" />
                        <ui:TextBlock
                                Margin="0,2,0,0"
                                FontTypography="Body"
                                Text="{Binding LastRunTime, StringFormat=g}"
                                Visibility="{Binding IsLastRunEmpty, Converter={StaticResource InverseBoolToVis}}" />
                        <controls:EmptyBadge
                                Margin="0,2,0,0"
                                Visibility="{Binding IsLastRunEmpty, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                    <ui:SymbolIcon
                            Grid.Column="2"
                            Margin="0,0,10,0"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Symbol="CalendarArrowRight24" />
                    <StackPanel Grid.Column="3">
                        <ui:TextBlock
                                Appearance="Secondary"
                                FontTypography="Caption"
                                Text="{ext:Loc ScheduledTasks.Details.NextRun}" />
                        <ui:TextBlock
                                Margin="0,2,0,0"
                                FontTypography="Body"
                                Text="{Binding NextRunTime, StringFormat=g}"
                                Visibility="{Binding IsNextRunEmpty, Converter={StaticResource InverseBoolToVis}}" />
                        <controls:EmptyBadge
                                Margin="0,2,0,0"
                                Visibility="{Binding IsNextRunEmpty, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Grid>
                <Separator Margin="14,0" />
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                            Margin="0,0,10,0"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Symbol="CheckmarkCircle24" />
                    <StackPanel Grid.Column="1">
                        <ui:TextBlock
                                Appearance="Secondary"
                                FontTypography="Caption"
                                Text="{ext:Loc ScheduledTasks.Details.LastResult}" />
                        <ui:TextBlock
                                Margin="0,2,0,0"
                                FontTypography="Body"
                                Text="{Binding LastRunResult}"
                                Visibility="{Binding IsLastResultEmpty, Converter={StaticResource InverseBoolToVis}}" />
                        <controls:EmptyBadge
                                Margin="0,2,0,0"
                                Visibility="{Binding IsLastResultEmpty, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
