<Page
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Margin="0,32,0,0"
    ScrollViewer.CanContentScroll="False"
    Title="ScheduledTasksPage"
    d:DataContext="{d:DesignInstance local:ScheduledTasksPage}"
    d:DesignHeight="1200"
    d:DesignWidth="800"
    mc:Ignorable="d"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    x:Class="optimizerDuck.UI.Views.Pages.ScheduledTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:local="clr-namespace:optimizerDuck.UI.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:optimizerDuck.Core.Models.ScheduledTask"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis" />
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        <converters:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibilityConverter" />
    </Page.Resources>

    <Grid RowDefinitions="Auto, *">
        <!--  Header  -->
        <StackPanel Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <ui:TextBlock FontTypography="Title" Text="{ext:Loc ScheduledTasks.Header.Title}" />
                    <ui:TextBlock
                        Appearance="Secondary"
                        FontTypography="Body"
                        Margin="0,4,0,0"
                        Text="{ext:Loc ScheduledTasks.Header.Description}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <WrapPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <ui:Button
                        Appearance="Primary"
                        Command="{Binding ViewModel.CreateTaskCommand}"
                        Content="{ext:Loc ScheduledTasks.Menu.CreateTask}"
                        Icon="{ui:SymbolIcon Add24,
                                             FontSize=18}"
                        Margin="0,0,8,0" />
                    <ui:Button
                        Appearance="Secondary"
                        Command="{Binding ViewModel.OpenTaskSchedulerCommand}"
                        Content="{ext:Loc ScheduledTasks.Menu.OpenSettings}"
                        Icon="{ui:SymbolIcon Settings24,
                                             FontSize=18}"
                        Margin="0,0,8,0" />
                    <ui:Button
                        Appearance="Secondary"
                        Command="{Binding ViewModel.RefreshCommand}"
                        Content="{ext:Loc StartupManager.Menu.Refresh}"
                        Icon="{ui:SymbolIcon ArrowClockwise24,
                                             FontSize=18}" />
                </WrapPanel>
            </Grid>
        </StackPanel>

        <!--  Loading Indicator  -->
        <Border Grid.Row="1" Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Height="48"
                    HorizontalAlignment="Center"
                    IsIndeterminate="True"
                    Margin="0,0,0,16"
                    VerticalAlignment="Center"
                    Width="48" />
                <ui:TextBlock
                    FontTypography="BodyStrong"
                    HorizontalAlignment="Center"
                    Text="{ext:Loc ScheduledTasks.Loading}" />
            </StackPanel>
        </Border>

        <!--  Main Content  -->
        <Grid
            Grid.Row="1"
            RowDefinitions="Auto,*"
            Visibility="{Binding ViewModel.IsNotLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Toolbar  -->
            <WrapPanel
                Grid.Row="0"
                Margin="0,0,16,12"
                Orientation="Horizontal">
                <!--  Search  -->
                <ui:TextBox
                    Icon="{ui:SymbolIcon Search24}"
                    Margin="0,0,8,0"
                    MinWidth="250"
                    PlaceholderText="{ext:Loc Common.Search.Placeholder}"
                    Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                    VerticalAlignment="Center" />

                <!--  Sort By  -->
                <ComboBox
                    Margin="0,0,8,0"
                    SelectedIndex="{Binding ViewModel.SortByIndex}"
                    ToolTip="{ext:Loc Common.SortBy}"
                    VerticalAlignment="Center">
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid ColumnDefinitions="Auto Auto" HorizontalAlignment="Left">
                            <ui:SymbolIcon
                                HorizontalAlignment="Left"
                                Margin="0,0,6,0"
                                Symbol="TextSortAscending24" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.Name}" />
                        </Grid>
                    </ComboBoxItem>
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid ColumnDefinitions="Auto Auto" HorizontalAlignment="Left">
                            <ui:SymbolIcon
                                HorizontalAlignment="Left"
                                Margin="0,0,6,0"
                                Symbol="ToggleRight24" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.Status}" />
                        </Grid>
                    </ComboBoxItem>
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid ColumnDefinitions="Auto Auto" HorizontalAlignment="Left">
                            <ui:SymbolIcon
                                HorizontalAlignment="Left"
                                Margin="0,0,6,0"
                                Symbol="Folder24" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.Path}" />
                        </Grid>
                    </ComboBoxItem>
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid ColumnDefinitions="Auto Auto" HorizontalAlignment="Left">
                            <ui:SymbolIcon
                                HorizontalAlignment="Left"
                                Margin="0,0,6,0"
                                Symbol="Flash24" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.State}" />
                        </Grid>
                    </ComboBoxItem>
                </ComboBox>

                <!--  Hide Microsoft  -->
                <ui:ToggleSwitch
                    Cursor="Hand"
                    IsChecked="{Binding ViewModel.HideMicrosoftTasks, Mode=TwoWay}"
                    Margin="0,0,8,0"
                    OffContent="{ext:Loc ScheduledTasks.HideMicrosoft}"
                    OnContent="{ext:Loc ScheduledTasks.HideMicrosoft}"
                    VerticalAlignment="Center" />

            </WrapPanel>

            <!--  No search results  -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                Margin="0,64,0,32"
                VerticalAlignment="Top"
                Visibility="{Binding ViewModel.Tasks.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                <ui:SymbolIcon
                    FontSize="36"
                    Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10"
                    Symbol="SearchInfo24" />
                <ui:TextBlock
                    Appearance="Secondary"
                    FontTypography="Body"
                    HorizontalAlignment="Center"
                    Text="{ext:Loc Bloatware.Search.NoResults}" />
            </StackPanel>

            <!--  Task List  -->
            <ScrollViewer Grid.Row="1" Margin="0,0,16,0">
                <ItemsControl ItemsSource="{Binding ViewModel.Tasks}" Visibility="{Binding ViewModel.Tasks.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ScheduledTaskModel}">
                            <Border
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="6"
                                Margin="0,0,0,6"
                                Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Task Logo  -->
                                    <Image
                                        Grid.Column="0"
                                        Height="36"
                                        Margin="0,0,12,0"
                                        Source="{Binding LogoImage}"
                                        Stretch="UniformToFill"
                                        VerticalAlignment="Center"
                                        Width="36" />

                                    <!--  Task info  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center">

                                        <!--  Row 1: Name + State badge  -->
                                        <DockPanel LastChildFill="False">
                                            <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Name}" />
                                            <Border
                                                CornerRadius="4"
                                                Margin="8,0,0,0"
                                                Padding="6,1"
                                                VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsReady}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDisabledState}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon
                                                        FontSize="10"
                                                        Margin="0,0,4,0"
                                                        x:Name="StateIcon">
                                                        <ui:SymbolIcon.Style>
                                                            <Style TargetType="ui:SymbolIcon">
                                                                <Setter Property="Symbol" Value="Circle24" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReady}" Value="True">
                                                                        <Setter Property="Symbol" Value="CheckmarkCircle24" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorInverseBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorInverseBrush}" />
                                                                        <Setter Property="Symbol" Value="Play24" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsDisabledState}" Value="True">
                                                                        <Setter Property="Symbol" Value="Dismiss24" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorInverseBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:SymbolIcon.Style>
                                                    </ui:SymbolIcon>
                                                    <ui:TextBlock
                                                        FontTypography="Caption"
                                                        Foreground="{Binding ElementName=StateIcon, Path=Foreground}"
                                                        Text="{Binding State}"
                                                        VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </DockPanel>

                                        <!--  Row 2: Description  -->
                                        <ui:TextBlock
                                            Appearance="Secondary"
                                            FontTypography="Caption"
                                            Margin="0,4,0,0"
                                            Text="{Binding Description}"
                                            TextWrapping="Wrap" />

                                        <!--  Row 3: Path  -->
                                        <ui:TextBlock
                                            Appearance="Disabled"
                                            FontTypography="Caption"
                                            Margin="0,2,0,0"
                                            Text="{Binding FullPath}" />

                                        <!--  Row 4: Trigger badges  -->
                                        <ItemsControl ItemsSource="{Binding TriggerTypes}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                                        CornerRadius="4"
                                                        Margin="0,0,4,2"
                                                        Padding="6,2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon
                                                                FontSize="10"
                                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                Margin="0,0,4,0"
                                                                Symbol="Timer24" />
                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                Text="{Binding}"
                                                                VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!--  Row 5: Action summary  -->
                                        <ui:TextBlock
                                            Appearance="Disabled"
                                            FontTypography="Caption"
                                            Margin="0,2,0,0"
                                            Text="{Binding ActionSummary}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!--  Actions  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                        <ui:Button
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Info24,
                                                                 FontSize=16}"
                                            Margin="0,0,4,0"
                                            Padding="8"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Details}" />
                                        <!--  Run: visible only when not running  -->
                                        <ui:Button
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.RunTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Play24,
                                                                 FontSize=16}"
                                            Margin="0,0,4,0"
                                            Padding="8"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Run}">
                                            <ui:Button.Style>
                                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <!--  Stop: visible only when running  -->
                                        <ui:Button
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.StopTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Stop24,
                                                                 FontSize=16}"
                                            Margin="0,0,4,0"
                                            Padding="8"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Stop}"
                                            Visibility="{Binding IsRunning, Converter={StaticResource WpfBoolToVis}}" />
                                        <ui:Button
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Delete24,
                                                                 FontSize=16}"
                                            Margin="0,0,8,0"
                                            Padding="8"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Delete}" />
                                        <ui:ToggleSwitch
                                            Cursor="Hand"
                                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                            OffContent="{ext:Loc Common.Toggle.Off}"
                                            OnContent="{ext:Loc Common.Toggle.On}"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
