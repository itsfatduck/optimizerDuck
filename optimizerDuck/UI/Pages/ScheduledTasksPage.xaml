<Page
    x:Class="optimizerDuck.UI.Pages.ScheduledTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:local="clr-namespace:optimizerDuck.UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:scheduledTask="clr-namespace:optimizerDuck.Domain.Optimizations.Models.ScheduledTask"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="ScheduledTasksPage"
    Style="{StaticResource DuckPageRootStyle}"
    d:DataContext="{d:DesignInstance local:ScheduledTasksPage}"
    d:DesignHeight="1200"
    d:DesignWidth="800"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d"
>
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis" />
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        <converters:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibilityConverter" />
    </Page.Resources>

    <Grid RowDefinitions="Auto, *">
        <!--  Header  -->
        <StackPanel Style="{StaticResource DuckPageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <ui:TextBlock
                        Style="{StaticResource DuckPageTitleStyle}"
                        Text="{ext:Loc ScheduledTasks.Header.Title}"
                    />
                    <ui:TextBlock
                        Style="{StaticResource DuckPageDescriptionStyle}"
                        Text="{ext:Loc ScheduledTasks.Header.Description}"
                    />
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Appearance="Secondary"
                        Command="{Binding ViewModel.OpenTaskSchedulerCommand}"
                        Content="{ext:Loc ScheduledTasks.Menu.OpenSettings}"
                        Icon="{ui:SymbolIcon Settings24,
                                             FontSize=18}"
                    />
                    <ui:Button
                        Appearance="Primary"
                        Command="{Binding ViewModel.RefreshCommand}"
                        Content="{ext:Loc StartupManager.Menu.Refresh}"
                        Icon="{ui:SymbolIcon ArrowClockwise24,
                                             FontSize=18}"
                        Visibility="{Binding ViewModel.ShowRefreshButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                    />
                </WrapPanel>
            </Grid>
        </StackPanel>

        <!--  Loading Indicator  -->
        <Border
            Grid.Row="1"
            Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
        >
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="48"
                    Height="48"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsIndeterminate="True"
                />
                <ui:TextBlock
                    HorizontalAlignment="Center"
                    FontTypography="BodyStrong"
                    Text="{ext:Loc ScheduledTasks.Loading}"
                />
                <ui:TextBlock
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    FontTypography="Caption"
                    Text="{ext:Loc ScheduledTasks.Loading.Hint}"
                />
            </StackPanel>
        </Border>

        <!--  Main Content  -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition
                                    Binding="{Binding ViewModel.IsNotLoading}"
                                    Value="True"
                                />
                                <Condition Binding="{Binding ViewModel.IsLoading}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!--  Toolbar  -->
            <Border Grid.Row="0" Style="{StaticResource DuckToolbarSurfaceStyle}">
            <WrapPanel Orientation="Horizontal">
                <!--  Search  -->
                <ui:TextBox
                    Style="{StaticResource DuckSearchBoxStyle}"
                    PlaceholderText="{ext:Loc Common.Search.Placeholder}"
                    Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                />

                <!--  Sort By  -->
                <ComboBox
                    Style="{StaticResource DuckComboBoxStyle}"
                    SelectedIndex="{Binding ViewModel.SortByIndex}"
                    ToolTip="{ext:Loc Common.SortBy}"
                >
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid HorizontalAlignment="Left" ColumnDefinitions="Auto Auto">
                            <ui:SymbolIcon
                                Margin="0,0,6,0"
                                HorizontalAlignment="Left"
                                Symbol="TextSortAscending24"
                            />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.Name}"
                            />
                        </Grid>
                    </ComboBoxItem>
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid HorizontalAlignment="Left" ColumnDefinitions="Auto Auto">
                            <ui:SymbolIcon
                                Margin="0,0,6,0"
                                HorizontalAlignment="Left"
                                Symbol="ToggleRight24"
                            />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.Status}"
                            />
                        </Grid>
                    </ComboBoxItem>
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid HorizontalAlignment="Left" ColumnDefinitions="Auto Auto">
                            <ui:SymbolIcon
                                Margin="0,0,6,0"
                                HorizontalAlignment="Left"
                                Symbol="Folder24"
                            />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.Path}"
                            />
                        </Grid>
                    </ComboBoxItem>
                    <ComboBoxItem HorizontalContentAlignment="Left">
                        <Grid HorizontalAlignment="Left" ColumnDefinitions="Auto Auto">
                            <ui:SymbolIcon
                                Margin="0,0,6,0"
                                HorizontalAlignment="Left"
                                Symbol="Flash24"
                            />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{ext:Loc Common.SortBy.State}"
                            />
                        </Grid>
                    </ComboBoxItem>
                </ComboBox>

                <!--  Hide Microsoft  -->
                <ui:ToggleSwitch
                    Style="{StaticResource DuckToggleSwitchStyle}"
                    IsChecked="{Binding ViewModel.HideMicrosoftTasks, Mode=TwoWay}"
                    OffContent="{ext:Loc ScheduledTasks.HideMicrosoft}"
                    OnContent="{ext:Loc ScheduledTasks.HideMicrosoft}"
                />
            </WrapPanel>
            </Border>

            <!--  No search results  -->
            <StackPanel
                Grid.Row="1"
                Style="{StaticResource DuckEmptyStatePanelStyle}"
                Visibility="{Binding ViewModel.Tasks.Count, Converter={StaticResource ZeroToVisibilityConverter}}"
            >
                <ui:SymbolIcon
                    Style="{StaticResource DuckEmptyStateIconStyle}"
                    Symbol="SearchInfo24"
                />
                <ui:TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource DuckSecondaryTextStyle}"
                    Text="{ext:Loc Bloatware.Search.NoResults}"
                />
            </StackPanel>

            <!--  Task List  -->
            <ScrollViewer Grid.Row="1" Margin="0,0,0,0">
                <ItemsControl
                    ItemsSource="{Binding ViewModel.Tasks}"
                    Visibility="{Binding ViewModel.Tasks.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}"
                >
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type scheduledTask:ScheduledTaskModel}">
                            <Border
                                Style="{StaticResource DuckListRowStyle}"
                            >
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Task Logo  -->
                                    <Image
                                        Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        Source="{Binding LogoImage}"
                                        Stretch="UniformToFill"
                                    />

                                    <!--  Task info  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                    >
                                        <!--  Row 1: Name + State badge  -->
                                        <DockPanel LastChildFill="False">
                                            <ui:TextBlock
                                                FontTypography="BodyStrong"
                                                Text="{Binding Name}"
                                            />
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                CornerRadius="4"
                                            >
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter
                                                            Property="Background"
                                                            Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                                        />
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                Binding="{Binding IsReady}"
                                                                Value="True"
                                                            >
                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{DynamicResource SystemFillColorSuccessBrush}"
                                                                />
                                                            </DataTrigger>
                                                            <DataTrigger
                                                                Binding="{Binding IsRunning}"
                                                                Value="True"
                                                            >
                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{DynamicResource AccentButtonBackground}"
                                                                />
                                                            </DataTrigger>
                                                            <DataTrigger
                                                                Binding="{Binding IsDisabledState}"
                                                                Value="True"
                                                            >
                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{DynamicResource SystemFillColorCriticalBrush}"
                                                                />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon
                                                        x:Name="StateIcon"
                                                        Margin="0,0,4,0"
                                                        FontSize="10"
                                                    >
                                                        <ui:SymbolIcon.Style>
                                                            <Style TargetType="ui:SymbolIcon">
                                                                <Setter
                                                                    Property="Symbol"
                                                                    Value="Circle24"
                                                                />
                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{DynamicResource TextFillColorPrimaryBrush}"
                                                                />
                                                                <Style.Triggers>
                                                                    <DataTrigger
                                                                        Binding="{Binding IsReady}"
                                                                        Value="True"
                                                                    >
                                                                        <Setter
                                                                            Property="Symbol"
                                                                            Value="CheckmarkCircle24"
                                                                        />
                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{DynamicResource TextFillColorInverseBrush}"
                                                                        />
                                                                    </DataTrigger>
                                                                    <DataTrigger
                                                                        Binding="{Binding IsRunning}"
                                                                        Value="True"
                                                                    >
                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{DynamicResource TextFillColorInverseBrush}"
                                                                        />
                                                                        <Setter
                                                                            Property="Symbol"
                                                                            Value="Play24"
                                                                        />
                                                                    </DataTrigger>
                                                                    <DataTrigger
                                                                        Binding="{Binding IsDisabledState}"
                                                                        Value="True"
                                                                    >
                                                                        <Setter
                                                                            Property="Symbol"
                                                                            Value="Dismiss24"
                                                                        />
                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{DynamicResource TextFillColorInverseBrush}"
                                                                        />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:SymbolIcon.Style>
                                                    </ui:SymbolIcon>
                                                    <ui:TextBlock
                                                        VerticalAlignment="Center"
                                                        FontTypography="Caption"
                                                        Foreground="{Binding ElementName=StateIcon, Path=Foreground}"
                                                        Text="{Binding State}"
                                                    />
                                                </StackPanel>
                                            </Border>
                                        </DockPanel>

                                        <!--  Row 2: Description  -->
                                        <ui:TextBlock
                                            Margin="0,4,0,0"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            FontTypography="Caption"
                                            Text="{Binding Description}"
                                            TextWrapping="Wrap"
                                        />

                                        <!--  Row 3: Path  -->
                                        <ui:TextBlock
                                            Margin="0,2,0,0"
                                            Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                            FontTypography="Caption"
                                            Text="{Binding FullPath}"
                                        />

                                        <!--  Row 4: Trigger badges  -->
                                        <ItemsControl
                                            Margin="0,4,0,0"
                                            ItemsSource="{Binding TriggerTypes}"
                                        >
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,0,4,2"
                                                        Padding="6,2"
                                                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                                        CornerRadius="4"
                                                    >
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon
                                                                Margin="0,0,4,0"
                                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                Symbol="Timer24"
                                                            />
                                                            <ui:TextBlock
                                                                VerticalAlignment="Center"
                                                                FontTypography="Caption"
                                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                Text="{Binding}"
                                                            />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!--  Row 5: Action summary  -->
                                        <ui:TextBlock
                                            Margin="0,2,0,0"
                                            Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                            FontTypography="Caption"
                                            Text="{Binding ActionSummary}"
                                            TextTrimming="CharacterEllipsis"
                                        />
                                    </StackPanel>

                                    <!--  Actions  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                    >
                                        <ui:Button
                                            Margin="0,0,4,0"
                                            Padding="8"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Info24,
                                                                 FontSize=16}"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Details}"
                                        />
                                        <!--  Run: visible only when not running  -->
                                        <ui:Button
                                            Margin="0,0,4,0"
                                            Padding="8"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.RunTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Play24,
                                                                 FontSize=16}"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Run}"
                                        >
                                            <ui:Button.Style>
                                                <Style
                                                    BasedOn="{StaticResource {x:Type ui:Button}}"
                                                    TargetType="ui:Button"
                                                >
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding IsRunning}"
                                                            Value="True"
                                                        >
                                                            <Setter
                                                                Property="Visibility"
                                                                Value="Collapsed"
                                                            />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <!--  Stop: visible only when running  -->
                                        <ui:Button
                                            Margin="0,0,4,0"
                                            Padding="8"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.StopTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Stop24,
                                                                 FontSize=16}"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Stop}"
                                            Visibility="{Binding IsRunning, Converter={StaticResource WpfBoolToVis}}"
                                        />
                                        <ui:Button
                                            Margin="0,0,8,0"
                                            Padding="8"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.ViewModel.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Delete24,
                                                                 FontSize=16}"
                                            ToolTip="{ext:Loc ScheduledTasks.Action.Delete}"
                                        />
                                        <ui:ToggleSwitch
                                            Style="{StaticResource DuckToggleSwitchStyle}"
                                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                            OffContent="{ext:Loc Common.Toggle.Off}"
                                            OnContent="{ext:Loc Common.Toggle.On}"
                                        />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
