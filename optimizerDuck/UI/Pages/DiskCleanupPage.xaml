<Page
    x:Class="optimizerDuck.UI.Pages.DiskCleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cleanup1="clr-namespace:optimizerDuck.Domain.Optimizations.Models.Cleanup"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:local="clr-namespace:optimizerDuck.UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="ThisPage"
    Title="DiskCleanupPage"
    d:DataContext="{d:DesignInstance local:DiskCleanupPage}"
    d:DesignHeight="1200"
    d:DesignWidth="800"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    Style="{StaticResource PageRootStyle}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter
            x:Key="InverseBooleanToVisibilityConverter"
            False="Visible"
            True="Collapsed" />
        <converters:SizeToBrushConverter x:Key="SizeToBrushConverter" />

        <!--  Clickable Name Style  -->
        <Style
            x:Key="ClickableNameStyle"
            BasedOn="{StaticResource DefaultUiHyperlinkButtonStyle}"
            TargetType="ui:HyperlinkButton">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding CanOpenFolder}" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CanOpenFolder}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid VerticalAlignment="Stretch" RowDefinitions="Auto,*">
        <!--  Header  -->
        <StackPanel Style="{StaticResource PageHeaderStyle}">
            <ui:TextBlock Style="{StaticResource PageTitleStyle}" Text="{ext:Loc DiskCleanup.Header.Title}" />
            <ui:TextBlock Style="{StaticResource PageDescriptionStyle}" Text="{ext:Loc DiskCleanup.Header.Description}" />
        </StackPanel>

        <!--  Loading State  -->
        <Border Grid.Row="1" Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="48"
                    Height="48"
                    Margin="0,0,0,16"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    HorizontalAlignment="Center"
                    FontTypography="BodyStrong"
                    Text="{ext:Loc DiskCleanup.Loading}" />
                <ui:TextBlock
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center"
                    FontTypography="Caption"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{ext:Loc DiskCleanup.Header.Description}" />
            </StackPanel>
        </Border>

        <!--  Main Content  -->
        <Grid
            Grid.Row="1"
            RowDefinitions="Auto,*"
            Visibility="{Binding ViewModel.HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Toolbar Card  -->
            <Border Style="{StaticResource ToolbarSurfaceStyle}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!--  Summary Info  -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <ui:TextBlock FontTypography="BodyStrong" Text="{ext:Loc DiskCleanup.TotalSpace}" />
                        <ui:TextBlock
                            Margin="0,2,0,0"
                            FontTypography="Caption"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{ext:Loc DiskCleanup.ItemsAndFilesSelected,
                                           {Binding ViewModel.TotalSelectedSizeFormatted},
                                           {Binding ViewModel.SelectedCount},
                                           {Binding ViewModel.TotalSelectedFileCount}}" />
                    </StackPanel>

                    <!--  Actions  -->
                    <WrapPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <!--  Select All / Deselect All  -->
                        <ui:Button
                            Cursor="Hand"
                            Command="{Binding ViewModel.ToggleSelectAllCommand}">
                            <ui:Button.Style>
                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                    <Setter Property="Appearance" Value="Success" />
                                    <Setter Property="Content" Value="{ext:Loc DiskCleanup.Button.SelectAll}" />
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <ui:SymbolIcon FontSize="16" Symbol="Checkmark24" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.IsAllSelected}" Value="True">
                                            <Setter Property="Appearance" Value="Danger" />
                                            <Setter Property="Content" Value="{ext:Loc DiskCleanup.Button.DeselectAll}" />
                                            <Setter Property="Icon">
                                                <Setter.Value>
                                                    <ui:SymbolIcon FontSize="16" Symbol="CheckboxUnchecked24" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>

                        <Separator Margin="4,0,4,0" />

                        <!--  Sort Dropdown  -->
                        <ComboBox
                            Cursor="Hand"
                            SelectedIndex="{Binding ViewModel.SelectedSortByIndex}"
                            ToolTip="{ext:Loc Common.SortBy}">
                            <ComboBoxItem HorizontalContentAlignment="Left">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <ui:SymbolIcon Margin="0,0,6,0" Symbol="Storage24" />
                                    <TextBlock Text="{ext:Loc Common.SortBy.Size}" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem HorizontalContentAlignment="Left">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <ui:SymbolIcon Margin="0,0,6,0" Symbol="TextSortAscending24" />
                                    <TextBlock Text="{ext:Loc Common.SortBy.Name}" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem HorizontalContentAlignment="Left">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <ui:SymbolIcon Margin="0,0,6,0" Symbol="Folder24" />
                                    <TextBlock Text="{ext:Loc Common.SortBy.Path}" />
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>

                        <!--  Clean Button  -->
                        <ui:Button
                            Appearance="Danger"
                            Command="{Binding ViewModel.CleanSelectedCommand}"
                            Cursor="Hand"
                            IsEnabled="{Binding ViewModel.CanClean}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Margin="0,0,6,0"
                                    FontSize="16"
                                    Symbol="Delete24" />
                                <TextBlock Text="{ext:Loc DiskCleanup.Button.CleanSelected, {Binding ViewModel.TotalSelectedSizeFormatted}}" />
                            </StackPanel>
                        </ui:Button>

                        <Separator Margin="8,0,8,0" />

                        <!--  Scan Button  -->
                        <Grid>
                            <ui:Button
                                Appearance="Primary"
                                Command="{Binding ViewModel.ScanCommand}"
                                Content="{ext:Loc DiskCleanup.Button.Scan}"
                                Cursor="Hand"
                                Icon="{ui:SymbolIcon Search24,
                                                     FontSize=16}"
                                Visibility="{Binding ViewModel.IsScanning, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            <ui:ProgressRing
                                Width="20"
                                Height="20"
                                Margin="8"
                                IsIndeterminate="True"
                                Visibility="{Binding ViewModel.IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </WrapPanel>
                </Grid>
            </Border>

            <!--  Items List  -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding ViewModel.CleanupItems}">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type cleanup1:CleanupItem}">
                        <Border Style="{StaticResource ListRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Checkbox  -->
                                <CheckBox
                                    Grid.Column="0"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                    <CheckBox.Style>
                                        <Style BasedOn="{StaticResource DefaultCheckBoxStyle}" TargetType="CheckBox">
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SizeBytes}" Value="0">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>

                                <!--  Icon  -->
                                <Border
                                    Grid.Column="1"
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="20">
                                    <ui:SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Symbol="{Binding Icon}" />
                                </Border>

                                <!--  Info Section  -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <!--  Clickable Name  -->
                                    <ui:HyperlinkButton
                                        Command="{Binding DataContext.ViewModel.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding CanOpenFolder}"
                                        Style="{StaticResource ClickableNameStyle}">


                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Name}" />
                                            <ui:SymbolIcon
                                                VerticalAlignment="Center"
                                                Symbol="Open24"
                                                Visibility="{Binding CanOpenFolder, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>


                                    </ui:HyperlinkButton>

                                    <!--  Description  -->
                                    <ui:TextBlock
                                        Margin="0,2,0,0"
                                        FontTypography="Caption"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap" />

                                    <!--  Path (truncated)  -->
                                    <ui:TextBlock
                                        Margin="0,2,0,0"
                                        FontTypography="Caption"
                                        Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                        Text="{Binding Path}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTip="{Binding Path}" />

                                    <!--  Size Badge  -->
                                    <Border
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Left"
                                        CornerRadius="{StaticResource CornerRadiusSmall}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Padding" Value="8,3" />
                                                <Setter Property="Background" Value="{Binding SizeBytes, Converter={StaticResource SizeToBrushConverter}}" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScanned}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <!--  Normal size display  -->
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FormattedSize}" Value="0 B">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <ui:TextBlock
                                                    FontTypography="Caption"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextFillColorInverseBrush}"
                                                    Text="{Binding FormattedSize}" />
                                                <ui:TextBlock
                                                    Margin="6,0"
                                                    FontTypography="Caption"
                                                    Foreground="{DynamicResource TextFillColorInverseBrush}"
                                                    Opacity="0.7"
                                                    Text="•" />
                                                <ui:TextBlock
                                                    FontTypography="Caption"
                                                    Foreground="{DynamicResource TextFillColorInverseBrush}"
                                                    Text="{ext:Loc DiskCleanup.FilesCount,
                                                                   {Binding FileCount}}" />
                                            </StackPanel>
                                            <!--  Empty state  -->
                                            <ui:TextBlock
                                                FontTypography="Caption"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{ext:Loc DiskCleanup.EmptySize}">
                                                <ui:TextBlock.Style>
                                                    <Style TargetType="ui:TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FormattedSize}" Value="0 B">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:TextBlock.Style>
                                            </ui:TextBlock>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!--  Actions: SplitButton + Progress  -->
                                <Grid
                                    Grid.Column="3"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">

                                    <!--  Scanning indicator  -->
                                    <ui:ProgressRing
                                        Width="20"
                                        Height="20"
                                        IsIndeterminate="True"
                                        Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <!--  Cleaning indicator  -->
                                    <ui:ProgressRing
                                        Width="20"
                                        Height="20"
                                        IsIndeterminate="True"
                                        Visibility="{Binding IsCleaning, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <ui:SplitButton
                                        Command="{Binding DataContext.ViewModel.CleanItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand"
                                        IsEnabled="{Binding IsScanned}"
                                        Visibility="{Binding ShowActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                Margin="0,0,4,0"
                                                FontSize="20"
                                                Symbol="Delete24" />
                                            <TextBlock VerticalAlignment="Center" Text="{ext:Loc DiskCleanup.Button.Clean}" />
                                        </StackPanel>

                                        <ui:SplitButton.Flyout>
                                            <ContextMenu>
                                                <MenuItem
                                                    Command="{Binding DataContext.ViewModel.RefreshItemCommand, Source={x:Reference ThisPage}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    Header="{ext:Loc StartupManager.Menu.Refresh}"
                                                    Icon="{ui:SymbolIcon ArrowClockwise24}" />
                                                <MenuItem
                                                    Command="{Binding DataContext.ViewModel.OpenFolderCommand, Source={x:Reference ThisPage}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    Header="{ext:Loc Common.OpenFolder}"
                                                    Icon="{ui:SymbolIcon OpenFolder24}"
                                                    IsEnabled="{Binding CanOpenFolder}" />
                                            </ContextMenu>
                                        </ui:SplitButton.Flyout>
                                    </ui:SplitButton>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Page>
