<Page
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Margin="0,32,0,0"
    ScrollViewer.CanContentScroll="False"
    Title="{Binding ViewModel.CategoryName}"
    d:DataContext="{d:DesignInstance features:FeatureCategoryPage}"
    d:DesignHeight="650"
    d:DesignWidth="800"
    mc:Ignorable="d"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    x:Class="optimizerDuck.UI.Pages.Features.FeatureCategoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:features="clr-namespace:optimizerDuck.UI.Pages.Features"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="42,0,42,16">
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <ui:SymbolIcon
                    FontSize="24"
                    Margin="0,0,12,0"
                    Symbol="{Binding ViewModel.CategoryIcon}"
                    VerticalAlignment="Center" />
                <ui:TextBlock
                    FontTypography="Title"
                    Text="{Binding ViewModel.CategoryName}"
                    VerticalAlignment="Center" />
            </StackPanel>
            <ui:TextBlock
                Appearance="Secondary"
                Text="{Binding ViewModel.CategoryDescription}"
                TextWrapping="Wrap" />
        </StackPanel>

        <WrapPanel
            Grid.Row="1"
            Margin="42,0,42,16"
            Orientation="Horizontal">
            <ui:TextBox
                HorizontalAlignment="Left"
                Icon="{ui:SymbolIcon Search24}"
                Margin="0,0,8,0"
                MinWidth="200"
                PlaceholderText="{ext:Loc Common.Search.Placeholder}"
                Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center" />

            <ComboBox
                Margin="0,0,8,0"
                SelectedIndex="{Binding ViewModel.SelectedSortByIndex}"
                ToolTip="{ext:Loc Common.SortBy}"
                VerticalAlignment="Center">
                <ComboBoxItem HorizontalContentAlignment="Left">
                    <Grid ColumnDefinitions="Auto Auto" HorizontalAlignment="Left">
                        <ui:SymbolIcon
                            HorizontalAlignment="Left"
                            Margin="0,0,6,0"
                            Symbol="TextSortAscending24" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Text="{ext:Loc Common.SortBy.Name}" />
                    </Grid>
                </ComboBoxItem>
                <ComboBoxItem HorizontalContentAlignment="Left">
                    <Grid ColumnDefinitions="Auto Auto" HorizontalAlignment="Left">
                        <ui:SymbolIcon
                            HorizontalAlignment="Left"
                            Margin="0,0,6,0"
                            Symbol="ToggleRight24" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Text="{ext:Loc Common.SortBy.Status}" />
                    </Grid>
                </ComboBoxItem>
            </ComboBox>
        </WrapPanel>

        <ScrollViewer
            Grid.Row="2"
            HorizontalScrollBarVisibility="Disabled"
            Margin="42,0,42,0"
            VerticalScrollBarVisibility="Auto">

            <!--  Sections  -->
            <ItemsControl ItemsSource="{Binding ViewModel.Sections}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,18">
                            <ui:TextBlock
                                FontTypography="BodyStrong"
                                Margin="0,0,0,6"
                                Text="{Binding Name}" />
                            <ItemsControl ItemsSource="{Binding Features}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:CardControl Margin="0,0,0,4">
                                            <ui:CardControl.Icon>
                                                <ui:SymbolIcon Symbol="{Binding Icon}" />
                                            </ui:CardControl.Icon>
                                            <ui:CardControl.Header>
                                                <StackPanel VerticalAlignment="Center">
                                                    <ui:TextBlock
                                                        FontTypography="Body"
                                                        Text="{Binding Name}"
                                                        TextWrapping="Wrap" />
                                                    <ui:TextBlock
                                                        Appearance="Secondary"
                                                        FontTypography="Caption"
                                                        Margin="0,4,0,0"
                                                        Text="{Binding Description}"
                                                        TextTrimming="WordEllipsis"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </ui:CardControl.Header>
                                            <ui:ToggleSwitch
                                                OffContent="{ext:Loc Common.Toggle.Off}"
OnContent="{ext:Loc Common.Toggle.On}"
                                                Command="{Binding ToggleCommand}"
                                                Cursor="Hand"
                                                HorizontalAlignment="Right"
                                                IsChecked="{Binding IsEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center" />
                                        </ui:CardControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Height="48"
                    HorizontalAlignment="Center"
                    IsIndeterminate="True"
                    Margin="0,0,0,16"
                    VerticalAlignment="Center"
                    Width="48" />
                <ui:TextBlock
                    FontTypography="BodyStrong"
                    HorizontalAlignment="Center"
                    Text="{ext:Loc Features.Loading}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>