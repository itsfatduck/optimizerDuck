<Page
    x:Class="optimizerDuck.UI.Pages.Features.FeatureCategoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:optimizerDuck.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:optimizerDuck.Common.Extensions"
    xmlns:features="clr-namespace:optimizerDuck.UI.Pages.Features"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{Binding ViewModel.CategoryName}"
    Style="{StaticResource DuckPageRootStyle}"
    d:DataContext="{d:DesignInstance features:FeatureCategoryPage}"
    d:DesignHeight="650"
    d:DesignWidth="800"
    ui:Design.Background="Black"
    ui:Design.Foreground="White"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Style="{StaticResource DuckPageHeaderStyle}">
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <ui:SymbolIcon
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{DynamicResource DuckAccentYellowBrush}"
                    Symbol="{Binding ViewModel.CategoryIcon}" />
                <ui:TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource DuckPageTitleStyle}"
                    Text="{Binding ViewModel.CategoryName}" />
            </StackPanel>
            <ui:TextBlock
                Style="{StaticResource DuckPageDescriptionStyle}"
                Text="{Binding ViewModel.CategoryDescription}"
                Margin="0" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Style="{StaticResource DuckToolbarSurfaceStyle}">
        <WrapPanel Orientation="Horizontal">
            <ui:TextBox
                Style="{StaticResource DuckSearchBoxStyle}"
                HorizontalAlignment="Left"
                PlaceholderText="{ext:Loc Common.Search.Placeholder}"
                Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox
                Style="{StaticResource DuckComboBoxStyle}"
                SelectedIndex="{Binding ViewModel.SelectedSortByIndex}"
                ToolTip="{ext:Loc Common.SortBy}"
                ToolTipService.BetweenShowDelay="160"
                ToolTipService.Placement="Top">
                <ComboBoxItem HorizontalContentAlignment="Left">
                    <Grid HorizontalAlignment="Left" ColumnDefinitions="Auto Auto">
                        <ui:SymbolIcon
                            Margin="0,0,6,0"
                            HorizontalAlignment="Left"
                            Symbol="TextSortAscending24" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Text="{ext:Loc Common.SortBy.Name}" />
                    </Grid>
                </ComboBoxItem>
                <ComboBoxItem HorizontalContentAlignment="Left">
                    <Grid HorizontalAlignment="Left" ColumnDefinitions="Auto Auto">
                        <ui:SymbolIcon
                            Margin="0,0,6,0"
                            HorizontalAlignment="Left"
                            Symbol="ToggleRight24" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Text="{ext:Loc Common.SortBy.Status}" />
                    </Grid>
                </ComboBoxItem>
            </ComboBox>
        </WrapPanel>
        </Border>

        <ScrollViewer
            Grid.Row="2"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <!--  Sections  -->
            <ItemsControl Style="{x:Null}" Margin="0" ItemsSource="{Binding ViewModel.Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,20">
                            <ui:TextBlock
                                Style="{StaticResource DuckSectionHeaderStyle}"
                                Text="{Binding Name}" />
                            <ItemsControl ItemsSource="{Binding Features}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:CardControl Margin="0,0,0,8">
                                            <ui:CardControl.Icon>
                                                <ui:SymbolIcon Symbol="{Binding Icon}" />
                                            </ui:CardControl.Icon>
                                            <ui:CardControl.Header>
                                                <StackPanel VerticalAlignment="Center">
                                                    <ui:TextBlock
                                                        FontTypography="Body"
                                                        Text="{Binding Name}"
                                                        TextWrapping="Wrap" />
                                                    <ui:TextBlock
                                                        Margin="0,4,0,0"
                                                        FontTypography="Caption"
                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding Description}"
                                                        TextTrimming="WordEllipsis"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </ui:CardControl.Header>
                                            <StackPanel
                                                Margin="0,0,0,0"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal">
                                                <ui:ToggleSwitch
                                                    Style="{StaticResource DuckToggleSwitchStyle}"
                                                    Command="{Binding ToggleCommand}"
                                                    Cursor="Hand"
                                                    IsChecked="{Binding IsEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                    OffContent="{ext:Loc Common.Toggle.Off}"
                                                    OnContent="{ext:Loc Common.Toggle.On}" />
                                                <ui:Button
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Command="{Binding DataContext.ViewModel.ViewSourceOnGitHubCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    Icon="{ui:SymbolIcon Code24}"
                                                    ToolTip="{ext:Loc Optimizer.Menu.ViewSource}" />
                                            </StackPanel>
                                        </ui:CardControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="48"
                    Height="48"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    HorizontalAlignment="Center"
                    FontTypography="BodyStrong"
                    Text="{ext:Loc Features.Loading}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
