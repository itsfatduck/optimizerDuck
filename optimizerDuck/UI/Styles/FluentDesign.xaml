<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <sys:Double x:Key="DuckSpace4">4</sys:Double>
    <sys:Double x:Key="DuckSpace8">8</sys:Double>
    <sys:Double x:Key="DuckSpace12">12</sys:Double>
    <sys:Double x:Key="DuckSpace16">16</sys:Double>
    <sys:Double x:Key="DuckSpace20">20</sys:Double>
    <sys:Double x:Key="DuckSpace24">24</sys:Double>
    <sys:Double x:Key="DuckSpace32">32</sys:Double>
    <sys:Double x:Key="DuckSpace40">40</sys:Double>

    <CornerRadius x:Key="DuckCornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="DuckCornerRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="DuckCornerRadiusLarge">12</CornerRadius>
    <Thickness x:Key="DuckPageMargin">42,32,42,0</Thickness>
    <Thickness x:Key="DuckPageInnerMargin">0,0,16,0</Thickness>
    <Thickness x:Key="DuckSectionMargin">0,0,0,24</Thickness>
    <Thickness x:Key="DuckSectionTopMargin">0,24,0,0</Thickness>
    <Thickness x:Key="DuckCardPadding">16,14</Thickness>
    <Thickness x:Key="DuckListRowPadding">16,12</Thickness>
    <Thickness x:Key="DuckToolbarPadding">16,12</Thickness>
    <Thickness x:Key="DuckControlGap">0,0,8,0</Thickness>
    <Thickness x:Key="DuckRowGap">0,0,0,8</Thickness>

    <Color x:Key="DuckAccentYellowColor">#FFFFD114</Color>
    <SolidColorBrush x:Key="DuckAccentYellowBrush" Color="{StaticResource DuckAccentYellowColor}" />
    <SolidColorBrush x:Key="DuckAccentYellowMutedBrush" Color="#33FFD114" />

    <Style x:Key="DuckPageRootStyle" TargetType="Page">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Margin" Value="{StaticResource DuckPageMargin}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="DuckPageHeaderStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="{StaticResource DuckSectionMargin}" />
    </Style>

    <Style x:Key="DuckPageTitleStyle" TargetType="ui:TextBlock">
        <Setter Property="FontTypography" Value="Title" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DuckPageDescriptionStyle" TargetType="ui:TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Appearance" Value="Secondary" />
        <Setter Property="FontTypography" Value="Body" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DuckSectionHeaderStyle" TargetType="ui:TextBlock">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="FontTypography" Value="BodyStrong" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DuckSecondaryTextStyle" TargetType="ui:TextBlock">
        <Setter Property="Appearance" Value="Secondary" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DuckCaptionTextStyle" TargetType="ui:TextBlock">
        <Setter Property="Appearance" Value="Secondary" />
        <Setter Property="FontTypography" Value="Caption" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DuckToolbarSurfaceStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Padding" Value="{StaticResource DuckToolbarPadding}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource DuckCornerRadiusLarge}" />
    </Style>

    <Style x:Key="DuckCardSurfaceStyle" TargetType="Border">
        <Setter Property="Margin" Value="{StaticResource DuckRowGap}" />
        <Setter Property="Padding" Value="{StaticResource DuckCardPadding}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource DuckCornerRadiusMedium}" />
        <Setter Property="Opacity" Value="1" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="Opacity"
                            From="0"
                            To="1"
                            Duration="0:0:0.16" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DuckListRowStyle" TargetType="Border">
        <Setter Property="Margin" Value="{StaticResource DuckRowGap}" />
        <Setter Property="Padding" Value="{StaticResource DuckListRowPadding}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource DuckCornerRadiusMedium}" />
        <Setter Property="Opacity" Value="1" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="Opacity"
                            From="0"
                            To="1"
                            Duration="0:0:0.12" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DuckSubtlePillStyle" TargetType="Border">
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DuckCornerRadiusSmall}" />
    </Style>

    <Style x:Key="DuckRoundIconSurfaceStyle" TargetType="Border">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="20" />
    </Style>

    <Style x:Key="DuckEmptyStatePanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,64,0,32" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DuckEmptyStateIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="40" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
    </Style>

    <Style x:Key="DuckSearchBoxStyle" TargetType="ui:TextBox">
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="Margin" Value="{StaticResource DuckControlGap}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Icon" Value="{ui:SymbolIcon Search24}" />
    </Style>

    <Style x:Key="DuckToggleSwitchStyle" TargetType="ui:ToggleSwitch">
        <Setter Property="Margin" Value="{StaticResource DuckControlGap}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="DuckComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Margin" Value="{StaticResource DuckControlGap}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="150" />
    </Style>

    <Style x:Key="DuckSettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="{StaticResource DuckSectionTopMargin}" />
    </Style>

    <Style x:Key="DuckSettingsRowHeaderStyle" TargetType="StackPanel">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DuckDialogRootStyle" TargetType="Grid">
        <Setter Property="MinWidth" Value="420" />
    </Style>

    <Style x:Key="DuckDialogContentStackStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="DuckDialogIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="44" />
        <Setter Property="Foreground" Value="{DynamicResource DuckAccentYellowBrush}" />
    </Style>

    <Style x:Key="DuckContentPresenterGridItemStyle" TargetType="ContentPresenter">
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="DuckContentPresenterRowStyle" TargetType="ContentPresenter">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

</ResourceDictionary>
