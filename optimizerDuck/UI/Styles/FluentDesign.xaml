<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:optimizerDuck.UI.Behaviors"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLarge">12</CornerRadius>
    <Thickness x:Key="PageMargin">42,32,42,0</Thickness>
    <Thickness x:Key="PageInnerMargin">0,0,16,0</Thickness>
    <Thickness x:Key="SectionMargin">0,0,0,24</Thickness>
    <Thickness x:Key="SectionTopMargin">0,12,0,0</Thickness>
    <Thickness x:Key="CardPadding">16,14</Thickness>
    <Thickness x:Key="ListRowPadding">16,12</Thickness>
    <Thickness x:Key="ToolbarPadding">16,12</Thickness>
    <Thickness x:Key="ControlGap">0,0,8,0</Thickness>
    <Thickness x:Key="RowGap">0,0,0,8</Thickness>

    <Color x:Key="AccentYellowColor">#FFFFD114</Color>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource AccentYellowColor}" />
    <SolidColorBrush x:Key="AccentYellowMutedBrush" Color="#33FFD114" />

    <Style x:Key="PageRootStyle" TargetType="Page">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Margin" Value="{StaticResource PageMargin}" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="PageHeaderStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="{StaticResource SectionMargin}" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="ui:TextBlock">
        <Setter Property="FontTypography" Value="Title" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PageDescriptionStyle" TargetType="ui:TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="FontTypography" Value="Body" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="ui:TextBlock">
        <Setter Property="Margin" Value="0,0,0,5" />
        <Setter Property="FontTypography" Value="BodyStrong" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SecondaryTextStyle" TargetType="ui:TextBlock">
        <Setter Property="Appearance" Value="Secondary" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="ui:TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="FontTypography" Value="Caption" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ToolbarSurfaceStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Padding" Value="{StaticResource ToolbarPadding}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLarge}" />
    </Style>

    <Style x:Key="CardSurfaceStyle" TargetType="Border">
        <Setter Property="Margin" Value="{StaticResource RowGap}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
        <Setter Property="Opacity" Value="1" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="Opacity"
                            From="0"
                            To="1"
                            Duration="0:0:0.16" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ListRowStyle" TargetType="Border">
        <Setter Property="Margin" Value="{StaticResource RowGap}" />
        <Setter Property="Padding" Value="{StaticResource ListRowPadding}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style x:Key="SubtlePillStyle" TargetType="Border">
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSmall}" />
    </Style>

    <Style x:Key="RoundIconSurfaceStyle" TargetType="Border">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="20" />
    </Style>

    <Style x:Key="EmptyStatePanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,64,0,32" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="40" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
    </Style>

    <Style
        x:Key="SearchBoxStyle"
        BasedOn="{StaticResource DefaultUiTextBoxStyle}"
        TargetType="ui:TextBox">
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="Margin" Value="{StaticResource ControlGap}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style BasedOn="{StaticResource DefaultUiToggleSwitchStyle}" TargetType="ui:ToggleSwitch">
        <Setter Property="Margin" Value="{StaticResource ControlGap}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="LabelPosition" Value="Left" />
    </Style>

    <Style BasedOn="{StaticResource DefaultComboBoxStyle}" TargetType="ComboBox">
        <Setter Property="Margin" Value="{StaticResource ControlGap}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="{StaticResource SectionTopMargin}" />
    </Style>

    <Style x:Key="SettingsRowHeaderStyle" TargetType="StackPanel">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DialogRootStyle" TargetType="Grid">
        <Setter Property="MinWidth" Value="420" />
    </Style>

    <Style x:Key="DialogContentStackStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="DialogIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="FontSize" Value="44" />
        <Setter Property="Foreground" Value="{DynamicResource AccentYellowBrush}" />
    </Style>

    <Style x:Key="ContentPresenterGridItemStyle" TargetType="ContentPresenter">
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="ContentPresenterRowStyle" TargetType="ContentPresenter">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="behaviors:SmoothScrollBehavior.IsEnabled" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.Smoothing" Value="0.20" />
        <Setter Property="behaviors:SmoothScrollBehavior.Multiplier" Value="1.3" />
    </Style>

</ResourceDictionary>
